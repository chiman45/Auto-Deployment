{
  "name": "devops-code-reviewer",
  "displayName": "DevOps AI Code Reviewer",
  "description": "🚀 AI-powered DevOps analyzer that detects and auto-fixes Docker, YAML, and K8s issues using local Ollama models",
  "version": "1.0.0",
  "publisher": "devops-tools",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Linters",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "docker",
    "kubernetes",
    "yaml",
    "devops",
    "ai",
    "ollama",
    "code-review",
    "auto-fix"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chiman45/devops-code-reviewer"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devops-code-reviewer.analyzeRepo",
        "title": "DevOps AI: Analyze Repository",
        "icon": "$(search)"
      },
      {
        "command": "devops-code-reviewer.analyzeCurrentFile",
        "title": "DevOps AI: Analyze Current File",
        "icon": "$(file-code)"
      },
      {
        "command": "devops-code-reviewer.showResults",
        "title": "DevOps AI: Show Analysis Results",
        "icon": "$(list-tree)"
      },
      {
        "command": "devops-code-reviewer.configure",
        "title": "DevOps AI: Configure Settings",
        "icon": "$(gear)"
      }
    ],
    "configuration": {
      "title": "DevOps AI Code Reviewer",
      "properties": {
        "devopsReviewer.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to Python executable"
        },
        "devopsReviewer.scriptPath": {
          "type": "string",
          "default": "${workspaceFolder}/../new.py",
          "description": "Path to new.py analyzer script"
        },
        "devopsReviewer.githubToken": {
          "type": "string",
          "default": "",
          "description": "GitHub Personal Access Token (stored securely)"
        },
        "devopsReviewer.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama API URL"
        },
        "devopsReviewer.autoFix": {
          "type": "boolean",
          "default": true,
          "description": "Automatically fix detected issues"
        },
        "devopsReviewer.autoBuildDocker": {
          "type": "boolean",
          "default": false,
          "description": "Automatically build Docker containers after analysis"
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "devops-code-reviewer.analyzeCurrentFile",
          "when": "resourceExtname =~ /\\.(yml|yaml|dockerfile)$/i",
          "group": "devops@1"
        }
      ],
      "explorer/context": [
        {
          "command": "devops-code-reviewer.analyzeRepo",
          "group": "devops@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.48.1",
    "eslint": "^9.39.1",
    "esbuild": "^0.27.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
